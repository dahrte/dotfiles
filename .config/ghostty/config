# Generated by Spectre - Ghostty Config Generator
# https://spectre-ghostty-config.vercel.app/editor

# Fonts
font-family = "JetBrainsMono NFM"
font-style = Medium

# Colors
theme = "Catppuccin Mocha"

# Window
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
# background-opacity = 0.8
background-blur-radius = 90

# Cursor
cursor-style-blink = true

# Shell
shell-integration = zsh

# Application
maximize = true
title = Ghostty

# Clipboard
copy-on-select = clipboard

# Keybinds
keybind = cmd+g>r=reload_config
keybind = cmd+g>w=close_surface

keybind = cmd+g>t=new_tab
keybind = cmd+g>1=goto_tab:1
keybind = cmd+g>2=goto_tab:2
keybind = cmd+g>3=goto_tab:3
keybind = cmd+g>4=goto_tab:4
keybind = cmd+g>5=goto_tab:5
keybind = cmd+g>6=goto_tab:6
keybind = cmd+g>7=goto_tab:7
keybind = cmd+g>8=goto_tab:8
keybind = cmd+g>9=goto_tab:9
keybind = cmd+[=previous_tab
keybind = cmd+]=next_tab

keybind = cmd+g>left=new_split:left
keybind = cmd+g>up=new_split:up
keybind = cmd+g>right=new_split:right
keybind = cmd+g>down=new_split:down
keybind = alt+up=goto_split:up
keybind = alt+right=goto_split:right
keybind = alt+down=goto_split:down
keybind = alt+left=goto_split:left
